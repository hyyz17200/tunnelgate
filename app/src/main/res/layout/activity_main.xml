<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/status_ready" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/section_diagnostics"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSuStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/diag_checking_su" />

        <TextView
            android:id="@+id/tvLsposedStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/diag_checking_lsposed" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRefreshStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/button_refresh_status" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnClearLogs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/button_clear_logs" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swAutomationEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_automation_enabled" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/section_control_backend"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgControlMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbModeShell"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_shell" />

            <RadioButton
                android:id="@+id/rbModeTasker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_tasker" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/layoutTaskerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_tasker_capture"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/tasker_help" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCaptureStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/button_capture_start" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnCaptureStop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/button_capture_stop" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnClearTasker"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/button_clear_tasker" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTaskerStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/tasker_start_unset" />

            <TextView
                android:id="@+id/tvTaskerStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/tasker_stop_unset" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutShellSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_shell_help"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/shell_help" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_start_command"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etStartCommand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_start_command"
                android:inputType="textMultiLine"
                android:minLines="2" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_stop_command"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etStopCommand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_stop_command"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_cellular"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgCellular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbCellularStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_enable_proxy" />

            <RadioButton
                android:id="@+id/rbCellularStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_disable_proxy" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_wifi_blacklist"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgWifiBlacklist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbWifiBlacklistStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_enable_proxy" />

            <RadioButton
                android:id="@+id/rbWifiBlacklistStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_disable_proxy" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_wifi_other"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgWifiOther"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbWifiOtherStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_enable_proxy" />

            <RadioButton
                android:id="@+id/rbWifiOtherStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_disable_proxy" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_no_network"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgNoNetwork"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbNoNetworkStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_enable_proxy" />

            <RadioButton
                android:id="@+id/rbNoNetworkStop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_disable_proxy" />
        </RadioGroup>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swRequireValidated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_require_validated" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_blacklist"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etBlacklist"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top|start"
            android:hint="@string/hint_blacklist"
            android:inputType="textMultiLine"
            android:minLines="5"
            android:scrollbars="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_debounce"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDebounce"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="2000"
            android:inputType="number" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_boot_delay"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etBootDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="8000"
            android:inputType="number" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/button_save" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnRestoreDefaults"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/button_restore_defaults" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnManualStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/button_manual_start" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnManualStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/button_manual_stop" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/section_logs"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#22000000"
            android:padding="12dp"
            android:text="@string/logs_empty"
            android:textIsSelectable="true"
            android:typeface="monospace"
            android:maxHeight="300dp"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/tvDeveloper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:autoLink="web"
            android:linksClickable="true"
            android:text="@string/developer_signature" />

    </LinearLayout>
</ScrollView>